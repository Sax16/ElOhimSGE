// Elohim SGE — schema R1
// Reglas heredadas del prototipo: dinero en NUMERIC(10,2); nada se borra (anulación con motivo);
// entidades anuales llevan academicYearId; enums con valores en español (glosario del proyecto).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Enums =====

enum UserRole {
  ADMIN
  SECRETARIA_CAJA
  DOCENTE
  PORTERIA
  APODERADO
}

enum UserStatus {
  ACTIVO
  SUSPENDIDO
}

enum YearStatus {
  ACTIVO
  CERRADO
}

enum PeriodType {
  BIMESTRE
  TRIMESTRE
  SEMESTRE
}

enum PeriodStatus {
  CERRADO
  EN_CURSO
  PROXIMO
}

enum Shift {
  MANANA
  TARDE
}

enum ProgramType {
  TALLER
  REFORZAMIENTO
  ACADEMIA
}

enum ProgramStatus {
  ACTIVO
  CERRADO
}

enum Sex {
  M
  F
}

enum InsuranceType {
  SIS
  ESSALUD
  PRIVADO
  NINGUNO
}

enum StudentStatus {
  ACTIVO
  BECADO
  RETIRADO
  TRASLADADO
  EGRESADO
  RESERVADO
}

enum NotificationChannel {
  WHATSAPP_Y_CORREO
  SOLO_WHATSAPP
  SOLO_CORREO
  NINGUNO
}

enum GuardianRelation {
  MADRE
  PADRE
  ABUELO_A
  TIO_A
  TUTOR_LEGAL
}

enum EnrollmentType {
  NUEVA
  RATIFICADA
  TRASLADO
}

enum EnrollmentStatus {
  COMPLETA
  PENDIENTE_PAGO
  OBSERVADA
}

enum InstallmentType {
  MATRICULA
  PENSION
}

enum InstallmentStatus {
  PAGADO
  PENDIENTE
  VENCIDO
  ANULADO
  EXONERADO
}

enum DiscountApplication {
  AUTOMATICO
  MANUAL
}

enum ActiveStatus {
  ACTIVO
  INACTIVO
}

enum PaymentMethod {
  EFECTIVO
  YAPE_PLIN
  TRANSFERENCIA
  TARJETA
}

enum CashSessionStatus {
  ABIERTA
  CERRADA
}

enum ReceiptStatus {
  EMITIDO
  ANULADO
}

enum CommitmentStatus {
  PROPUESTO
  VIGENTE
  CUMPLIDO
  INCUMPLIDO
  RECHAZADO
  ANULADO
}

enum CommitmentFrequency {
  MENSUAL
  QUINCENAL
}

enum RefundStatus {
  PENDIENTE_APROBACION
  APROBADA
  RECHAZADA
  DEVUELTA
}

enum RefundMethod {
  EFECTIVO
  TRANSFERENCIA
  APLICACION_CUOTA
}

enum TreasuryKind {
  GASTO
  INGRESO
}

enum TreasuryOrigin {
  MANUAL
  CAJA_CHICA
}

enum PettyRenditionSource {
  EFECTIVO_CAJA
  TRANSFERENCIA
}

// ===== Identity / Configuración =====

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  username           String     @unique
  passwordHash       String
  fullName           String
  role               UserRole
  status             UserStatus @default(ACTIVO)
  permissions        Json // { [modulo]: { ver: boolean, editar: boolean } }
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  tutorOf                      Section[]            @relation("SectionTutor")
  courses                      Course[]             @relation("CourseTeacher")
  enrollmentsRegistered        Enrollment[]         @relation("RegisteredBy")
  programEnrollmentsRegistered ProgramEnrollment[]  @relation("ProgramEnrollmentRegisteredBy")
  auditLogs                    AuditLog[]
  cashSessionsOpened           CashSession[]        @relation("CashSessionOpenedBy")
  cashSessionsClosed           CashSession[]        @relation("CashSessionClosedBy")
  receiptsCashiered            Receipt[]            @relation("ReceiptCashier")
  receiptsCanceled             Receipt[]            @relation("ReceiptCanceledBy")
  lateFeesExonerated           Installment[]        @relation("InstallmentLateFeeExoneratedBy")
  remindersSent                ReminderLog[]        @relation("ReminderSentBy")
  commitmentsProposed          PaymentCommitment[]  @relation("CommitmentProposedBy")
  commitmentsApproved          PaymentCommitment[]  @relation("CommitmentApprovedBy")
  commitmentsCanceled          PaymentCommitment[]  @relation("CommitmentCanceledBy")
  refundsRequested             Refund[]             @relation("RefundRequestedBy")
  refundsApproved              Refund[]             @relation("RefundApprovedBy")
  refundsExecuted              Refund[]             @relation("RefundExecutedBy")
  treasuryMovementsRegistered  TreasuryMovement[]   @relation("TreasuryMovementRegisteredBy")
  treasuryMovementsCanceled    TreasuryMovement[]   @relation("TreasuryMovementCanceledBy")
  pettyCashFundResponsibleOf   PettyCashFund[]      @relation("PettyCashFundResponsible")
  pettyCashExpensesRegistered  PettyCashExpense[]   @relation("PettyCashExpenseRegisteredBy")
  pettyCashExpensesCanceled    PettyCashExpense[]   @relation("PettyCashExpenseCanceledBy")
  pettyCashRenditionsMade      PettyCashRendition[] @relation("PettyCashRenditionRegisteredBy")
}

// Singleton (id = 1): datos institucionales de la pestaña Configuración > Institución.
model Institution {
  id          Int      @id @default(1)
  name        String
  modularCode String // asignado por MINEDU
  ruc         String
  address     String
  phone       String
  email       String
  region      String
  ugel        String
  motto       String?
  logoUrl     String?
  updatedAt   DateTime @updatedAt
}

// Singleton (id = 1): configuración de cobranza (Tarifario y becas > Mora por atraso).
model BillingSettings {
  id                Int      @id @default(1)
  lateFeeAmount     Decimal  @default(5.00) @db.Decimal(10, 2)
  graceDays         Int      @default(3)
  transferCutoffDay Int      @default(20) // día de corte de traslados: ingresa antes → paga el mes
  autoLateFee       Boolean  @default(true)
  dueDayOfMonth     Int? // null = último día del mes
  updatedAt         DateTime @updatedAt
}

// Append-only: nunca UPDATE/DELETE sobre esta tabla.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // "enrollment.create", "section.update", "user.suspend"...
  entity    String
  entityId  String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

// ===== Estructura académica (anualizada) =====

model AcademicYear {
  id              String     @id @default(cuid())
  name            String     @unique // "2026"
  startDate       DateTime   @db.Date
  endDate         DateTime   @db.Date
  periodType      PeriodType
  enrollmentStart DateTime   @db.Date
  status          YearStatus @default(ACTIVO)

  periods     Period[]
  levels      Level[]
  programs    Program[]
  enrollments Enrollment[]
}

model Period {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String // "Bimestre I"
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  status         PeriodStatus @default(PROXIMO)
  order          Int

  @@unique([academicYearId, order])
}

model Level {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String // "Inicial", "Primaria", "Secundaria", "Academia"
  description    String? // rango: "3–5 años"
  order          Int

  grades GradeLevel[]
  fee    LevelFee?

  @@unique([academicYearId, name])
}

model GradeLevel {
  id      String @id @default(cuid())
  levelId String
  level   Level  @relation(fields: [levelId], references: [id])
  name    String // "3 años" | "3°"
  order   Int

  sections Section[]
  courses  Course[]

  @@unique([levelId, name])
}

model Section {
  id            String     @id @default(cuid())
  gradeLevelId  String
  gradeLevel    GradeLevel @relation(fields: [gradeLevelId], references: [id])
  name          String // "A" | "Los Girasoles" (Inicial usa nombres)
  shift         Shift
  capacity      Int // vacantes con límite por sección
  tutorId       String?
  tutor         User?      @relation("SectionTutor", fields: [tutorId], references: [id])
  assistantName String? // auxiliar (texto libre hasta que exista el módulo Personal en R3)

  enrollments Enrollment[]

  @@unique([gradeLevelId, name, shift])
}

model Course {
  id           String     @id @default(cuid())
  gradeLevelId String
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id])
  name         String // "Matemática", "Comunicación"...
  weeklyHours  Int
  teacherId    String?
  teacher      User?      @relation("CourseTeacher", fields: [teacherId], references: [id])

  @@unique([gradeLevelId, name])
}

model Program {
  id             String        @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])
  name           String
  type           ProgramType
  scheduleText   String // "Sáb 9:00–11:00"
  capacity       Int
  startMonth     Int // mes de inicio de la vigencia (2..12)
  endMonth       Int // mes de fin de la vigencia (2..12, >= startMonth)
  enrollmentFee  Decimal       @db.Decimal(10, 2) // matrícula del programa (0 = sin pago)
  monthlyFee     Decimal       @db.Decimal(10, 2)
  status         ProgramStatus @default(ACTIVO)

  programEnrollments ProgramEnrollment[]

  // Reapertura = nueva edición: el mismo nombre puede repetirse si el periodo (startMonth) difiere.
  @@unique([academicYearId, name, startMonth])
}

// Inscripción de un estudiante a una edición de programa (independiente de la matrícula escolar).
// Genera sus propias cuotas (Installment con programEnrollmentId); nada se borra (cancelación con motivo).
model ProgramEnrollment {
  id                    String    @id @default(cuid())
  programId             String
  program               Program   @relation(fields: [programId], references: [id])
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id])
  registeredById        String
  registeredBy          User      @relation("ProgramEnrollmentRegisteredBy", fields: [registeredById], references: [id])
  enrolledAt            DateTime  @default(now())
  monthlyFeeSnapshot    Decimal   @db.Decimal(10, 2) // congelado al inscribir
  enrollmentFeeSnapshot Decimal   @default(0) @db.Decimal(10, 2)
  canceledAt            DateTime?
  cancelReason          String?

  installments Installment[]

  @@unique([programId, studentId])
}

// Tarifario por nivel: alimenta la generación automática del cronograma.
// Cambiarlo NO altera cronogramas ya generados (los montos se copian a Installment).
model LevelFee {
  id                String   @id @default(cuid())
  levelId           String   @unique
  level             Level    @relation(fields: [levelId], references: [id])
  enrollmentFee     Decimal  @db.Decimal(10, 2)
  monthlyFee        Decimal  @db.Decimal(10, 2)
  installmentsCount Int // 10 (mar–dic) u 11 (feb–dic)
  updatedAt         DateTime @updatedAt
}

model Discount {
  id          String              @id @default(cuid())
  code        String?             @unique // "HERMANOS" para la regla automática
  name        String
  percent     Decimal             @db.Decimal(5, 2) // sobre la pensión, nunca matrícula/programas
  application DiscountApplication
  condition   String
  status      ActiveStatus        @default(ACTIVO)

  enrollments Enrollment[]
}

// ===== Personas =====

model Student {
  id               String        @id @default(cuid())
  code             String        @unique // "E-1042"
  firstNames       String
  paternalLastName String // apellido paterno (obligatorio)
  maternalLastName String? // apellido materno (opcional: cubre personas con un solo apellido)
  dni              String        @unique @db.Char(8)
  birthDate        DateTime      @db.Date
  sex              Sex
  address          String
  previousSchool   String?
  photoUrl         String?
  status           StudentStatus @default(ACTIVO)
  shift            Shift?

  // Salud y emergencia (ficha)
  allergies             String? // visible para tutor y auxiliar
  insuranceType         InsuranceType @default(NINGUNO)
  emergencyContactName  String?
  emergencyContactPhone String?
  authorizedPickups     Json          @default("[]") // [{ name, dni?, relation }]

  // Retiro / traslado saliente (nada se borra)
  withdrawalReason String?
  withdrawnAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guardians          StudentGuardian[]
  enrollments        Enrollment[]
  programEnrollments ProgramEnrollment[]
  receipts           Receipt[]
  refunds            Refund[]
}

model Guardian {
  id                  String              @id @default(cuid())
  code                String              @unique // "A-0211"
  fullName            String
  dni                 String              @unique @db.Char(8)
  phone               String // WhatsApp
  email               String?
  address             String
  notificationChannel NotificationChannel @default(SOLO_WHATSAPP)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  students           StudentGuardian[]
  enrollmentsSigned  Enrollment[]        @relation("SigningGuardian")
  reminderLogs       ReminderLog[]
  paymentCommitments PaymentCommitment[]
}

// Relación N:M estudiante↔apoderado. Desvincular = active:false (soft), nunca DELETE.
model StudentGuardian {
  studentId  String
  guardianId String
  student    Student          @relation(fields: [studentId], references: [id])
  guardian   Guardian         @relation(fields: [guardianId], references: [id])
  relation   GuardianRelation
  isPrimary  Boolean          @default(false) // contacto principal: recibe notificaciones de pago
  active     Boolean          @default(true)

  @@id([studentId, guardianId])
}

// ===== Matrícula y cronograma =====

model Enrollment {
  id             String           @id @default(cuid())
  code           String           @unique // "M-2026-0483"
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id])
  sectionId      String
  section        Section          @relation(fields: [sectionId], references: [id])
  academicYearId String
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  type           EnrollmentType
  status         EnrollmentStatus @default(PENDIENTE_PAGO)

  signingGuardianId String
  signingGuardian   Guardian @relation("SigningGuardian", fields: [signingGuardianId], references: [id])
  registeredById    String
  registeredBy      User     @relation("RegisteredBy", fields: [registeredById], references: [id])
  enrolledAt        DateTime @default(now())

  discountId String?
  discount   Discount? @relation(fields: [discountId], references: [id])

  // siagieCode: histórico de traslados (ya no se captura en el flujo actual).
  siagieCode String?   @db.Char(14)
  entryDate  DateTime? @db.Date // define desde cuándo se cobran pensiones

  // Anulación con justificación (nada se borra)
  canceledAt   DateTime?
  cancelReason String?

  installments Installment[]

  // Unicidad estudiante+año SOLO para matrículas vigentes: índice único parcial WHERE canceledAt
  // IS NULL (creado por migración SQL, no representable en el schema Prisma). Permite re-matricular
  // a quien se retiró/trasladó (su matrícula previa quedó anulada).
}

// Una cuota pertenece a una matrícula ESCOLAR (enrollmentId) o a una inscripción de PROGRAMA
// (programEnrollmentId) — exactamente una de las dos (CHECK en la BD).
model Installment {
  id                  String             @id @default(cuid())
  enrollmentId        String?
  enrollment          Enrollment?        @relation(fields: [enrollmentId], references: [id])
  programEnrollmentId String?
  programEnrollment   ProgramEnrollment? @relation(fields: [programEnrollmentId], references: [id])
  type                InstallmentType
  concept             String // "Matrícula" | "Pensión Marzo" | "Programa · Taller de Danza · Marzo"
  sequence            Int // 0 = matrícula, 1..N = cuotas
  dueDate             DateTime           @db.Date
  baseAmount          Decimal            @db.Decimal(10, 2) // snapshot del tarifario
  discountAmount      Decimal            @default(0) @db.Decimal(10, 2)
  programsAmount      Decimal            @default(0) @db.Decimal(10, 2)
  amount              Decimal            @db.Decimal(10, 2) // total = base - descuento + programas
  status              InstallmentStatus  @default(PENDIENTE)

  // Mora fija (R2 — E2): una sola vez por cuota, solo pensión escolar. 0 = sin mora / exonerada.
  lateFeeAmount            Decimal   @default(0) @db.Decimal(10, 2)
  lateFeeAppliedAt         DateTime? // cuándo el job cargó la mora
  lateFeeExoneratedAt      DateTime? // cuándo un Admin exoneró la mora (congela el recargo)
  lateFeeExoneratedById    String?
  lateFeeExoneratedBy      User?     @relation("InstallmentLateFeeExoneratedBy", fields: [lateFeeExoneratedById], references: [id])
  lateFeeExonerationReason String? // motivo de exoneración (≥ 10 caracteres, CHECK en BD)

  canceledAt   DateTime?
  cancelReason String?
  canceledById String?

  receiptItems     ReceiptItem[]
  commitmentItems  CommitmentInstallment[]
  refundsTargeting Refund[]                @relation("RefundTargetInstallment")

  @@unique([enrollmentId, sequence])
  @@unique([programEnrollmentId, sequence])
}

// Recordatorio de pago enviado a un apoderado principal (R2 — E2): snapshot del mensaje y total.
// Semiautomático vía WhatsApp (wa.me); el envío queda trazado (quién, a quién, cuándo, cuánto).
model ReminderLog {
  id          String   @id @default(cuid())
  guardianId  String
  guardian    Guardian @relation(fields: [guardianId], references: [id])
  sentById    String
  sentBy      User     @relation("ReminderSentBy", fields: [sentById], references: [id])
  channel     String   @default("WHATSAPP")
  message     String
  totalAmount Decimal  @db.Decimal(10, 2)
  itemsCount  Int
  createdAt   DateTime @default(now())

  @@index([guardianId, createdAt])
}

// ===== Caja y cobros (R2 — E1) =====

// Catálogo simple de "otros conceptos" (libros, uniformes, buzo…): nombre + precio, sin stock.
// La integración con Inventario llega en R5. Administrable desde Tarifario.
model SaleConcept {
  id        String       @id @default(cuid())
  name      String       @unique
  price     Decimal      @db.Decimal(10, 2)
  status    ActiveStatus @default(ACTIVO)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  items ReceiptItem[]
}

// Una caja compartida POR DÍA (única por fecha). Quien la abre registra el monto inicial y
// responde por el arqueo; cualquier usuario con permiso caja puede cobrar sobre ella.
model CashSession {
  id            String            @id @default(cuid())
  date          DateTime          @unique @db.Date // una caja por día civil
  status        CashSessionStatus @default(ABIERTA)
  openedById    String
  openedBy      User              @relation("CashSessionOpenedBy", fields: [openedById], references: [id])
  openedAt      DateTime          @default(now())
  initialAmount Decimal           @db.Decimal(10, 2)
  closedById    String?
  closedBy      User?             @relation("CashSessionClosedBy", fields: [closedById], references: [id])
  closedAt      DateTime?
  expectedCash  Decimal?          @db.Decimal(10, 2) // inicial + efectivo de recibos EMITIDO
  countedCash   Decimal?          @db.Decimal(10, 2)
  difference    Decimal?          @db.Decimal(10, 2) // countedCash − expectedCash
  closeNotes    String?

  receipts            Receipt[]
  refunds             Refund[]
  treasuryMovements   TreasuryMovement[]
  pettyCashRenditions PettyCashRendition[]
}

// Recibo interno numerado (R-2026-#####). Registra quién cobró; anulación mientras la caja siga abierta.
model Receipt {
  id              String        @id @default(cuid())
  code            String        @unique // "R-2026-04313"
  cashSessionId   String
  cashSession     CashSession   @relation(fields: [cashSessionId], references: [id])
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id])
  guardianName    String? // snapshot del apoderado principal al cobrar
  guardianPhone   String?
  method          PaymentMethod
  operationNumber String?
  totalAmount     Decimal       @db.Decimal(10, 2)
  receivedAmount  Decimal?      @db.Decimal(10, 2) // solo EFECTIVO
  changeAmount    Decimal?      @db.Decimal(10, 2) // vuelto (solo EFECTIVO)
  status          ReceiptStatus @default(EMITIDO)
  cashierId       String
  cashier         User          @relation("ReceiptCashier", fields: [cashierId], references: [id])
  createdAt       DateTime      @default(now())
  canceledAt      DateTime?
  cancelReason    String?
  canceledById    String?
  canceledBy      User?         @relation("ReceiptCanceledBy", fields: [canceledById], references: [id])

  items   ReceiptItem[]
  refunds Refund[]

  @@index([cashSessionId])
  @@index([studentId])
}

// Línea de recibo: una cuota escolar/programa (installmentId) o una venta de catálogo (saleConceptId),
// exactamente una de las dos (CHECK en la BD). Guarda snapshot del concepto y montos.
model ReceiptItem {
  id            String       @id @default(cuid())
  receiptId     String
  receipt       Receipt      @relation(fields: [receiptId], references: [id], onDelete: Restrict)
  installmentId String?
  installment   Installment? @relation(fields: [installmentId], references: [id])
  saleConceptId String?
  saleConcept   SaleConcept? @relation(fields: [saleConceptId], references: [id])
  concept       String // snapshot del concepto
  quantity      Int          @default(1)
  unitAmount    Decimal      @db.Decimal(10, 2)
  amount        Decimal      @db.Decimal(10, 2) // unitAmount × quantity
}

// ===== Compromisos de pago (R2 — E3) =====

// Un compromiso reprograma 1:1 cuotas VENCIDAS de los hijos del apoderado firmante:
// Secretaría propone → Admin aprueba (VIGENTE). Mientras VIGENTE y al día, la "fecha efectiva"
// de cada cuota es su newDueDate — de ahí se derivan estado, deuda, mora y recordatorios (congelamiento).
model PaymentCommitment {
  id           String              @id @default(cuid())
  code         String              @unique // "CP-0001"
  guardianId   String
  guardian     Guardian            @relation(fields: [guardianId], references: [id])
  proposedById String
  proposedBy   User                @relation("CommitmentProposedBy", fields: [proposedById], references: [id])
  approvedById String?
  approvedBy   User?               @relation("CommitmentApprovedBy", fields: [approvedById], references: [id])
  status       CommitmentStatus    @default(PROPUESTO)
  frequency    CommitmentFrequency
  firstDueDate DateTime            @db.Date
  totalAmount  Decimal             @db.Decimal(10, 2) // snapshot Σ (amount + mora) al proponer

  rejectReason String?
  cancelReason String?
  canceledById String?
  canceledBy   User?   @relation("CommitmentCanceledBy", fields: [canceledById], references: [id])

  approvedAt  DateTime?
  breachedAt  DateTime? // el job lo marcó INCUMPLIDO
  fulfilledAt DateTime? // última cuota pagada → CUMPLIDO
  createdAt   DateTime  @default(now())

  items CommitmentInstallment[]
}

// Cuota reprogramada por un compromiso: nueva fecha y snapshot del monto (amount + mora) al proponer.
// Una cuota no puede estar en dos compromisos PROPUESTO/VIGENTE a la vez (validado en el service).
model CommitmentInstallment {
  id            String            @id @default(cuid())
  commitmentId  String
  commitment    PaymentCommitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  installmentId String
  installment   Installment       @relation(fields: [installmentId], references: [id])
  sequence      Int
  newDueDate    DateTime          @db.Date
  amount        Decimal           @db.Decimal(10, 2)

  @@unique([installmentId, commitmentId])
}

// ===== Devoluciones (R2 — E3) =====

// Devolución vinculada a un recibo EMITIDO: Secretaría solicita → Admin aprueba/rechaza → Caja ejecuta.
// Ejecución: EFECTIVO (egreso del arqueo del día), TRANSFERENCIA (n° de operación) o APLICACION_CUOTA
// (marca una cuota del mismo estudiante como PAGADO, monto exacto — sin saldo a favor).
model Refund {
  id                  String       @id @default(cuid())
  code                String       @unique // "D-0001"
  receiptId           String
  receipt             Receipt      @relation(fields: [receiptId], references: [id])
  studentId           String
  student             Student      @relation(fields: [studentId], references: [id])
  requestedById       String
  requestedBy         User         @relation("RefundRequestedBy", fields: [requestedById], references: [id])
  amount              Decimal      @db.Decimal(10, 2)
  reason              String
  method              RefundMethod
  targetInstallmentId String?
  targetInstallment   Installment? @relation("RefundTargetInstallment", fields: [targetInstallmentId], references: [id])
  status              RefundStatus @default(PENDIENTE_APROBACION)

  approvedById String?
  approvedBy   User?     @relation("RefundApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  rejectReason String?

  executedById    String?
  executedBy      User?        @relation("RefundExecutedBy", fields: [executedById], references: [id])
  executedAt      DateTime?
  cashSessionId   String?
  cashSession     CashSession? @relation(fields: [cashSessionId], references: [id])
  operationNumber String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([receiptId])
}

// ===== Tesorería (R2 — E4): gastos, otros ingresos y caja chica =====

// Categoría administrable de gasto/ingreso. Se elimina solo si no tiene movimientos (si no, se desactiva).
model TreasuryCategory {
  id        String       @id @default(cuid())
  kind      TreasuryKind
  name      String
  status    ActiveStatus @default(ACTIVO)
  createdAt DateTime     @default(now())

  movements TreasuryMovement[]

  @@unique([kind, name])
}

// Movimiento de dinero de tesorería: un gasto (G-####) o un otro ingreso (I-####).
// origin MANUAL = registrado a mano (editable/anulable); CAJA_CHICA = generado por una rendición
// (no editable, se corrige por su rendición). Un INGRESO en EFECTIVO se vincula a la caja del día
// (cashSessionId) y suma al arqueo; los gastos nunca tocan el cajón salvo la reposición de caja chica.
model TreasuryMovement {
  id             String           @id @default(cuid())
  code           String           @unique // "G-0001" | "I-0001"
  kind           TreasuryKind
  categoryId     String
  category       TreasuryCategory @relation(fields: [categoryId], references: [id])
  description    String
  amount         Decimal          @db.Decimal(10, 2)
  method         PaymentMethod
  date           DateTime         @db.Date
  supplier       String?
  voucherNumber  String?
  notes          String?
  origin         TreasuryOrigin   @default(MANUAL)
  originRef      String? // "REND-0001" cuando origin = CAJA_CHICA
  cashSessionId  String?
  cashSession    CashSession?     @relation(fields: [cashSessionId], references: [id])
  registeredById String
  registeredBy   User             @relation("TreasuryMovementRegisteredBy", fields: [registeredById], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  canceledAt     DateTime?
  cancelReason   String?
  canceledById   String?
  canceledBy     User?            @relation("TreasuryMovementCanceledBy", fields: [canceledById], references: [id])

  rendition PettyCashRendition?

  @@index([kind, date])
  @@index([cashSessionId])
}

// Fondo fijo de caja chica (singleton id = 1): monto + responsable configurables (solo ADMIN).
model PettyCashFund {
  id            Int      @id @default(1)
  amount        Decimal  @default(500.00) @db.Decimal(10, 2)
  responsibleId String?
  responsible   User?    @relation("PettyCashFundResponsible", fields: [responsibleId], references: [id])
  updatedAt     DateTime @updatedAt
}

// Gasto menor contra el fondo de caja chica. Anulable con motivo mientras no esté rendido;
// la rendición lo consolida (renditionId) en un gasto de tesorería y repone el fondo.
model PettyCashExpense {
  id             String              @id @default(cuid())
  date           DateTime            @db.Date
  concept        String
  amount         Decimal             @db.Decimal(10, 2)
  voucherNumber  String?
  registeredById String
  registeredBy   User                @relation("PettyCashExpenseRegisteredBy", fields: [registeredById], references: [id])
  renditionId    String?
  rendition      PettyCashRendition? @relation(fields: [renditionId], references: [id])
  createdAt      DateTime            @default(now())
  canceledAt     DateTime?
  cancelReason   String?
  canceledById   String?
  canceledBy     User?               @relation("PettyCashExpenseCanceledBy", fields: [canceledById], references: [id])

  @@index([renditionId])
}

// Rendición de caja chica (REND-####): consolida los gastos menores no rendidos en UN gasto de
// tesorería (treasuryMovementId, origin CAJA_CHICA) y repone el fondo. Origen del dinero:
// EFECTIVO_CAJA (egresa de la caja del día, vincula cashSessionId) o TRANSFERENCIA (libre).
model PettyCashRendition {
  id                 String               @id @default(cuid())
  code               String               @unique // "REND-0001"
  totalAmount        Decimal              @db.Decimal(10, 2)
  expensesCount      Int
  source             PettyRenditionSource
  treasuryMovementId String               @unique
  treasuryMovement   TreasuryMovement     @relation(fields: [treasuryMovementId], references: [id])
  cashSessionId      String?
  cashSession        CashSession?         @relation(fields: [cashSessionId], references: [id])
  registeredById     String
  registeredBy       User                 @relation("PettyCashRenditionRegisteredBy", fields: [registeredById], references: [id])
  createdAt          DateTime             @default(now())

  expenses PettyCashExpense[]
}

// Secuencias de códigos legibles: "student" → E-####, "guardian" → A-####, "enrollment:2026" → M-2026-####
model CodeCounter {
  key   String @id
  value Int
}

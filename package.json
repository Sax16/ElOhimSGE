{
  "name": "elohim-sge",
  "private": true,
  "version": "0.1.0",
  "description": "Sistema de Gestión Escolar — I.E.P. Elohim (Satipo, Junín)",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "concurrently -n shared,api,web -c blue,green,magenta \"pnpm --filter @elohim/shared dev\" \"pnpm --filter @elohim/api start:dev\" \"pnpm --filter @elohim/web dev\"",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @elohim/api db:migrate",
    "db:seed": "pnpm --filter @elohim/shared build && pnpm --filter @elohim/api db:seed",
    "db:studio": "pnpm --filter @elohim/api db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
